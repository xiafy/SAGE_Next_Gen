#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

COMMIT_MSG_FILE="$1"
FIRST_LINE="$(head -n 1 "$COMMIT_MSG_FILE")"

echo -e "${YELLOW}[commit-msg] Validating commit message...${NC}"

# Skip merge commits
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  echo -e "${YELLOW}[commit-msg] Merge commit detected, skipping checks.${NC}"
  exit 0
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

# Allow-empty: no staged files → nothing to enforce
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Rule A: prompt changes must include structured Before/After lines
if echo "$STAGED_FILES" | grep -qE '^worker/prompts/'; then
  echo -e "${YELLOW}[commit-msg] Prompt changes detected. Checking Before/After in commit message...${NC}"

  BEFORE_LINE="$(grep -iE '^Before:[[:space:]]*[^[:space:]]' "$COMMIT_MSG_FILE" || true)"
  AFTER_LINE="$(grep -iE '^After:[[:space:]]*[^[:space:]]' "$COMMIT_MSG_FILE" || true)"

  if [ -z "$BEFORE_LINE" ] || [ -z "$AFTER_LINE" ]; then
    echo -e "${RED}[commit-msg] ERROR: Changes under worker/prompts/ require I/O diff in commit message.${NC}"
    echo -e "${RED}Please add BOTH lines with non-empty content:${NC}"
    echo "  Before: <old prompt behavior/output>"
    echo "  After:  <new prompt behavior/output>"
    echo ""
    echo "Example:"
    echo "  feat: refine menu extraction prompt"
    echo ""
    echo "  Before: Sometimes returned missing price fields for combo items"
    echo "  After: Always outputs price for combo items with fallback parsing"
    exit 1
  fi

  echo -e "${GREEN}[commit-msg] Prompt I/O diff check passed.${NC}"
fi

# Rule B: fix commits must include test changes
if echo "$FIRST_LINE" | grep -qE '^fix(\([^)]+\))?:[[:space:]]'; then
  echo -e "${YELLOW}[commit-msg] fix commit detected. Checking staged test files...${NC}"

  if ! echo "$STAGED_FILES" | grep -qE '\.test\.'; then
    echo -e "${RED}[commit-msg] ERROR: fix commit must include at least one staged test file (*.test.*).${NC}"
    echo "How to fix:"
    echo "  1) Add or update a test file (e.g. app/src/**/xxx.test.ts)"
    echo "  2) git add the test file"
    echo "  3) retry commit"
    echo ""
    echo "If this is a docs fix, use 'docs:' prefix instead of 'fix:'."
    exit 1
  fi

  echo -e "${GREEN}[commit-msg] fix/test linkage check passed.${NC}"
fi

echo -e "${GREEN}[commit-msg] Commit message checks passed.${NC}"
exit 0
