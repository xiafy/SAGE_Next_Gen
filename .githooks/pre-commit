#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo -e "${YELLOW}[pre-commit] Running checks...${NC}"

if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  echo -e "${YELLOW}[pre-commit] Merge commit detected, skipping checks.${NC}"
  exit 0
fi

command -v npx >/dev/null || {
  echo -e "${RED}[pre-commit] npx not found. Please install Node.js/npm so npx is available, then retry commit.${NC}"
  exit 1
}

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}[pre-commit] No staged files. Skip.${NC}"
  exit 0
fi

# Docs-only detection
DOCS_ONLY=1
while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    docs/*|*.md|*.mdx|*.txt)
      ;;
    *)
      DOCS_ONLY=0
      break
      ;;
  esac
done <<EOF_DOCS
$STAGED_FILES
EOF_DOCS

if [ "$DOCS_ONLY" -eq 1 ]; then
  echo -e "${YELLOW}[pre-commit] Docs-only changes detected. Skipping compile and tests.${NC}"
  exit 0
fi

# Detect change scope
APP_CHANGED=0
WORKER_CHANGED=0
SHARED_CHANGED=0

while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    app/*) APP_CHANGED=1 ;;
    worker/*) WORKER_CHANGED=1 ;;
    shared/*) SHARED_CHANGED=1 ;;
  esac
done <<EOF_SCOPE
$STAGED_FILES
EOF_SCOPE

# Rule 1: TypeScript compile
if [ "$APP_CHANGED" -eq 1 ] || [ "$SHARED_CHANGED" -eq 1 ]; then
  echo -e "${YELLOW}[pre-commit] Type checking app...${NC}"
  if ! ( cd "$REPO_ROOT/app" && npx tsc --noEmit ); then
    echo -e "${RED}[pre-commit] App type check FAILED.${NC}"
    exit 1
  fi
  echo -e "${GREEN}[pre-commit] App type check passed.${NC}"
fi

if [ "$WORKER_CHANGED" -eq 1 ] || [ "$SHARED_CHANGED" -eq 1 ]; then
  echo -e "${YELLOW}[pre-commit] Type checking worker...${NC}"
  if ! ( cd "$REPO_ROOT/worker" && npx tsc --noEmit ); then
    echo -e "${RED}[pre-commit] Worker type check FAILED.${NC}"
    exit 1
  fi
  echo -e "${GREEN}[pre-commit] Worker type check passed.${NC}"
fi

# Rule 2: Tests
if [ "$APP_CHANGED" -eq 1 ] || [ "$SHARED_CHANGED" -eq 1 ]; then
  echo -e "${YELLOW}[pre-commit] Running app tests...${NC}"
  if ! ( cd "$REPO_ROOT/app" && npx vitest run ); then
    echo -e "${RED}[pre-commit] App tests FAILED.${NC}"
    exit 1
  fi
  echo -e "${GREEN}[pre-commit] App tests passed.${NC}"
fi

echo -e "${GREEN}[pre-commit] All checks passed.${NC}"
exit 0
